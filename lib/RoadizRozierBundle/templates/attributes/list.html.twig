{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}attributes{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<rz-bulk-section>
    {% include '@RoadizRozier/attributes/head.html.twig' with {
        title: 'attributes'|trans,
        filters: filters,
        buttons: [
            {
                label: 'add.a.attribute'|trans,
                href: path('attributesAddPage'),
                icon: 'rz-icon-ri--add-line'
            },
            {
                label: 'attribute_groups'|trans,
                href: path('attributeGroupsHomePage'),
                icon: 'rz-icon-ri--folder-2-line'
            },
            {
                label: 'export.all'|trans,
                href: path('attributesExportPage'),
                icon: 'rz-icon-ri--download-line'
            },
            {
                label: 'import'|trans,
                href: path('attributesImportPage'),
                icon: 'rz-icon-ri--upload-line'
            },
        ]
    } only %}

    {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: true,
    }  only %}
    {% include '@RoadizRozier/admin/bulk_actions.html.twig' %}
    <article class="content content-no-action-menu">
        <div class="content-table-cont">
            <table class="items content-table uk-table attributes">
                <thead>
                    <tr>
                        {% include '@RoadizRozier/attributes/attribute_row_header.html.twig' %}
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        <tr>
                            {% include '@RoadizRozier/attributes/attribute_row.html.twig' %}
                        </tr>
                    {% else %}
                        <tr><td colspan="4">{% trans %}no_attributes{% endtrans %}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </article>
</rz-bulk-section>
{% endblock %}
