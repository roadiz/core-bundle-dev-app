{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}import.attributes{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global import-item">
    {% include '@RoadizRozier/attributes/head.html.twig' with {
        title: 'import.attributes'|trans
    } only %}

    <article class="content content-no-action-menu">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: {id: "import-item-form"}}) }}
            {{ form_widget(form) }}
            <div class="rz-button-group rz-button-group--gap-md">
                <a class="rz-button rz-button--secondary rz-button-group__button"
                   href="{{ path('attributesHomePage') }}"
                >
                    <span class="rz-button__label">{% trans %}cancel{% endtrans %}</span>
                    <span class="rz-button__icon rz-icon-ri--corner-down-left-line"></span>
                </a>
                <button is="rz-button" type="submit" class="rz-button rz-button--primary rz-button-group__button">
                    <span class="rz-button__label">{% trans %}import{% endtrans %}</span>
                    <span class="rz-button__icon rz-icon-ri--upload-line"></span>
                </button>
            </div>
        {{ form_end(form) }}
    </article>
</section>
{% endblock %}
