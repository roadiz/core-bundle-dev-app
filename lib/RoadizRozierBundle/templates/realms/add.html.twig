{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% block realm_title %}{% trans %}add.a.realm{% endtrans %}{% endblock %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global add-realm">
    {% include '@RoadizRozier/realms/head.html.twig' with {
        title: block('realm_title')
    } only %}

    {% block content_body %}
    <article class="content">
        {%- block content_body_before -%}{%- endblock -%}
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, {
            'attr': {
                'id': 'edit-realm-form',
                'class': 'uk-form uk-form-stacked'
            }
        }) }}{{ form_widget(form) }}
        {% import "@RoadizRozier/macros/rz_actions_menu.html.twig" as actions_menu %}
        {{ actions_menu.saveItem('#edit-realm-form') }}
        {{ form_end(form) }}
        {%- block content_body_after -%}{%- endblock -%}
    </article>
    {% include '@RoadizRozier/realms/actionsMenu.html.twig' %}
    {% endblock %}
</section>
{% endblock %}
