{% extends '@RoadizRozier/layout.html.twig' %}
{% set tTag = tag.getTranslatedTags.first %}

{%- block title -%}
    {{ tTag.getName }}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global content-nav-and-filters">
    {% include '@RoadizRozier/tags/head.html.twig' with {
        title: tTag.getName,
        filters: filters,
        with_nav_bar: true,
        tag: tag,
        current: 'nodes',
        available_translations, available_translations,
        translation: translation
    } only %}

    {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: false,
    }  only %}

    <article class="content content-no-action-menu content-tags-nodes">
        <div class="content-table-cont">
            <table class="tags content-table uk-table">
                <thead>
                {% include '@RoadizRozier/nodes/widgets/node-header.html.twig' with {
                    'filters': filters,
                    'with_select_action': false
                } only %}
                </thead>
                <tbody>
                    {% for node in nodes %}
                        {% include '@RoadizRozier/nodes/widgets/node-row.html.twig' with {
                            'node': node,
                            'with_select_action': false
                        } only %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </article>

</section>
{% endblock %}
