{% set popover_id = id|default('rz-dropdown-' ~ random()) %}
{% set placement = placement|default('bottom-end') %}
{% set offset = offset|default('12') %}
{% set shift = shift|default('0') %}

{% set _opts = target_options|default({}) %}
{% set _attrs = _opts.attributes|default({})|merge({
		'popovertarget': popover_id,
		type: 'button',
	}) %}
{% set button_options = _opts|merge({ attributes: _attrs })%}

<rz-popover
	popover-placement="{{ placement }}"
	popover-offset="{{ offset }}"
	popover-shift="{{ shift }}"
	{% for attrname, attrvalue in attributes %}
		{% if attrvalue and attrvalue is same as(true) %}
			{{ attrname }}
		{% else %}
			{{ attrname }}="{{ attrvalue }}"
		{% endif %}
	{% endfor %}
>
	{% import "@RoadizRozier/macros/rz_button.html.twig" as rz_button %}
	{{ rz_button.root(button_options) }}

	{% block popover %}{% endblock %}
</rz-popover>
