{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{{- "edit.group.%name%.users"|trans({'%name%': item.getName})|truncate_title }} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global edit-group">
    {% include '@RoadizRozier/groups/head.html.twig' with {
        title: 'edit.group.%name%.users'|trans({'%name%': item.name})|truncate_title(40),
        item: item,
        current: 'users',
        with_nav_bar: true,
        with_breadcrumb: true,
    } only %}

    <article>
        {% embed '@RoadizRozier/includes/rz_table.html.twig' with {
            selection_available: false,
            actions_available: true,
        } %}
            {% block thead_cells %}
                <th>{% trans %}user{% endtrans %}</th>
            {% endblock %}

            {% block tbody_content %}
                {% for user in item.getUsers %}
                <tr>
                    <td>{{ user.userName }}</td>
                    {% if actions_available %}
                        <td>
                            {% embed '@RoadizRozier/includes/rz_table_actions.html.twig' with {
                                'delete_href': path('groupsRemoveUsersPage', { id: item.getId, userId: user.getId }),
                                'delete_title': 'unlink.user'|trans,
                            } %}
                            {% endembed %}
                        </td>
                    {% endif %}
                </tr>
                {% endfor %}
            {% endblock %}
        {% endembed %}

        <hr />
        <h2>{% trans %}add.a.user{% endtrans %}</h2>

        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, {
            'attr': {
                'class': 'uk-form uk-form-stacked'
            }
        }) }}{{ form_widget(form) }}
            <fieldset data-uk-margin>
                <button class="uk-button uk-button-primary" type="submit">
                    <i class="uk-icon-rz-plus"></i> {% trans %}add.user{% endtrans %}
                </button>
            </fieldset>
        {{ form_end(form) }}
    </article>
    {% include '@RoadizRozier/groups/actionsMenu.html.twig' %}
</section>
{% endblock %}
