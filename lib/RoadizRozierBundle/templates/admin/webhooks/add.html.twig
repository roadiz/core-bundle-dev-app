{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}add.a.webhook{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global add-item">
    {% include '@RoadizRozier/admin/head.html.twig' with {
        title: "add.a.webhook"|trans,
    } only %}

    <article class="content content-add">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: { id: "add-webhook-form" }}) }}
            {{ form_widget(form) }}
            {% import "@RoadizRozier/macros/rz_actions_menu.html.twig" as actions_menu %}
            {{ actions_menu.saveItem('#add-webhook-form') }}
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/admin/webhooks/actionsMenu.html.twig' with {"item": item} only %}
</section>
{% endblock %}
