{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if item.getId %}
            {{ _self.item(
                label: 'delete',
                class: 'rz-button--error',
                href: path('settingsDeletePage', { id: item.getId}),
                icon: 'rz-icon-ri--delete-bin-7-line'
            ) }}
        {% endif %}
    {% endblock %}
{% endembed %}
