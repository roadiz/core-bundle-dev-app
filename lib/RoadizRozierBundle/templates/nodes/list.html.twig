{% extends '@RoadizRozier/layout.html.twig' %}

{% set mainTitle = mainFilter ~ '.nodes' %}

{% block title %}{{ mainTitle|trans()|truncate_title }} | {{ parent() }}{% endblock %}

{% block content %}
<rz-bulk-section>
    {% include '@RoadizRozier/nodes/head.html.twig' with {
        title: mainTitle|trans()|truncate_title,
        filters: filters,
        availableTranslations: availableTranslations,
        translation: translation,
        nodeTypes: nodeTypes,
        mainFilter: mainFilter,
    } only %}

    {% include '@RoadizRozier/nodes/filtersBar.html.twig' %}
    {% include '@RoadizRozier/nodes/bulkActions.html.twig' with {
        delete_form_data: deleteNodesForm|default(null),
        delete_form_action: path('nodesBulkDeletePage'),
        delete_form_method: 'post',
        tagNodesForm: tagNodesForm,
        statusNodesForm: statusNodesForm,
    } only %}

    <article class="content content-no-action-menu">
        <div class="content-table-cont">
            <table class="nodes content-table uk-table">
                <thead>
                {% include '@RoadizRozier/nodes/widgets/node-header.html.twig' with {
                    'filters': filters
                } only %}
                </thead>
                <tbody>
                    {% for node in nodes %}
                        {% include '@RoadizRozier/nodes/widgets/node-row.html.twig' with {
                            'node': node
                        } only %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </article>
</rz-bulk-section>
{% endblock %}
