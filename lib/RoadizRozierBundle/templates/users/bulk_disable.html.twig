{% extends '@RoadizRozier/users/bulk_base.html.twig' %}
{% block bulk_title %}{% trans %}users.bulk_disable.title{% endtrans %}{% endblock %}

{% block bulk_form %}
    {% if form %}
        <article class="content content-disable content-no-action-menu">
            {% form_theme form '@RoadizRozier/forms.html.twig' %}
            {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="rz-message rz-message--error rz-form-field__message">
                <p class="rz-message__text">
                    {% trans %}are_you_sure.bulk_disable.users{% endtrans %}
                </p>
            </div>
            <div class="rz-button-group rz-button-group--gap-md">
                {% import "@RoadizRozier/macros/rz_button.html.twig" as rz_button %}
                {{ rz_button.root({
                    attributes: {
                        href: path('usersHomePage'),
                    },
                    emphasis: 'secondary',
                    label: 'cancel',
                    icon: 'rz-icon-ri--corner-down-left-line',
                }) }}

				{{
					rz_button.root({
						attributes: {
							type: 'submit',
						},
                        label: 'bulk.disable'|trans,
						color: 'danger',
						emphasis: 'primary',
						icon: 'rz-icon-ri--delete-bin-7-line',
					})
				}}
            </div>
            {{ form_end(form) }}
        </article>
    {% endif %}
{% endblock %}
