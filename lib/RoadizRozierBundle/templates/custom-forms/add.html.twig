{% extends "@RoadizRozier/admin/base.html.twig" %}

{% block title %}{% trans %}add.a.customForm{% endtrans %} | {{ parent() }}{% endblock %}

{%- block content_title -%}{% trans %}add.a.customForm{% endtrans %}{%- endblock -%}

{%- block content_header_nav -%}
    <a class="content-header-nav-back uk-navbar-content"
       href="{{ path('customFormsHomePage') }}"
       title="{% trans %}back_to.customForms{% endtrans %}"
       data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
{%- endblock -%}

{%- block content_body -%}
    <article class="content">
        {%- block content_body_before -%}{%- endblock -%}
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{- form_start(form, {
            'attr': {
                'id': 'edit-customform-form',
                'class': 'uk-form uk-form-stacked'
            }
        }) -}}
        {{- form_widget(form) -}}
        {% import "@RoadizRozier/macros/rz_actions_menu.html.twig" as floating_bar %}
        {{ floating_bar.saveItem('#edit-customform-form') }}
        {{- form_end(form) -}}
        {%- block content_body_after -%}{%- endblock -%}
    </article>
    {% include '@RoadizRozier/custom-forms/actionsMenu.html.twig' %}
{%- endblock -%}
