{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {{ "delete.settingGroup.%name%"|trans({'%name%': item.getName })|truncate_title }}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global">
    {% include '@RoadizRozier/settingGroups/head.html.twig' with {
        title: "delete.settingGroup.%name%"|trans({'%name%': item.getName})|truncate_title
    } only %}

    <article class="content content-delete content-no-action-menu">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        <form class="uk-form uk-form-stacked" action="#" method="post">
            {{ form_widget(form) }}
            <fieldset data-uk-margin>
                <legend class="uk-alert uk-alert-danger"><i class="uk-icon uk-icon-warning"></i> {% trans %}are_you_sure.delete.settingGroup{% endtrans %}</legend>
                <a href="{{ path('settingGroupsHomePage') }}" class="uk-button"><i class="uk-icon-rz-back-parent"></i> {% trans %}cancel{% endtrans %}</a>
                <button class="uk-button uk-button-danger" type="submit">
                    <i class="uk-icon-rz-trash-o"></i> <span class="label">{% trans %}delete{% endtrans %}</span>
                </button>
            </fieldset>
        </form>
    </article>
</section>
{% endblock %}
