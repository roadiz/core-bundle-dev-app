{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {{ "edit.user.%name%.groups"|trans({'%name%': user.username })|truncate_title }}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global edit-user">

    <header class="content-header header-user header-user-edit">
        <h1 class="content-title user-add-title">{{ "edit.user.%name%.groups"|trans({'%name%': user.username })|truncate_title }}</h1>
        {% include '@RoadizRozier/users/navBar.html.twig' with {'user':user, current:'groups'} %}
    </header>

    <article class="content content-user-groups">
        <div class="content-table-cont">
            <table class="content-table users-groups uk-table">
                <thead>
                    <tr>
                        <th>{% trans %}group{% endtrans %}</th>
                        <th class="table-actions-row table-actions-row-2">{% trans %}actions{% endtrans %}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for group in user.getGroups %}
                    <tr>
                        <td><a href="{{ path('groupsEditPage', {'id':group.getId}) }}">{{ group.getName }}</a></td>
                        <td class="table-actions-row table-actions-row-2">
                        {% if is_granted(group) %}
                            <div class="rz-button-group rz-button-group--md rz-button-group--collapsed">
                                <a
                                    is="rz-link"
                                    tooltip-text="{% trans %}roles{% endtrans %}"
                                    popover-placement="top"
                                    popover-offset="4"
                                    class="rz-button rz-button--secondary rz-button-group__button"
                                    href="{{ path('groupsEditRolesPage', { id: group.getId }) }}"
                                >
                                    <span class="rz-button__icon rz-icon-ri--star-line"></span>
                                </a>
                                <a
                                    is="rz-link"
                                    tooltip-text="{% trans %}unlink{% endtrans %}"
                                    popover-placement="top"
                                    popover-offset="4"
                                    class="rz-button rz-button--primary rz-button--danger rz-button-group__button"
                                    href="{{ path('usersRemoveGroupsPage', { userId: user.getId, groupId: group.getId }) }}"
                                >
                                    <span class="rz-button__icon rz-icon-ri--delete-bin-7-line"></span>
                                </a>
                            </div>
                        {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <hr />
        <h2>{% trans %}add.a.group{% endtrans %}</h2>

        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="rz-form-field rz-form-field--align-start">
                <button class="rz-button rz-button--primary" type="submit">
                    <span class="rz-button__label">{% trans %}add.group{% endtrans %}</span>
                    <span class="rz-button__icon rz-icon-ri--add-line"></span>
                </button>
            </div>
        {{ form_end(form) }}
    </article>
    {% include '@RoadizRozier/users/actionsMenu.html.twig' %}
</section>
{% endblock %}
