{% set currentTitle = source.title|default(node.nodeName) %}
{% set pageTitle = "edit.node.%name%.tags"|trans({'%name%': currentTitle})|u.truncate(25, '[…]', true) %}

{% extends '@RoadizRozier/layout.html.twig' %}
{% import "@RoadizRozier/macros/rz_status_badge.html.twig" as rz_status_badge %}

{% block title %}{{ pageTitle }} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global" data-page-title="{{ pageTitle }} – {% trans %}back_office{% endtrans %}">
    {% if not source %}
        {% set source = node.nodeSources.first %}
    {% endif %}
    {% set breadcrumb = {
        'label': 'node-breadcrumb',
        'parent': source|parents(null, true)|reverse,
        'current': source.title|default(node.nodeName)
    } %}
    {% embed "@RoadizRozier/macros/rz_page_header.html.twig" with {
        breadcrumb: breadcrumb
    } %}
        {% block translation %}
            <div class="rz-page-header__item">
                {% include '@RoadizRozier/nodes/translationBar.html.twig' with {"current": translation.getId} %}
            </div>
        {% endblock %}
        {% block breadcrumb %}
            {{ _self.breadcrumb(breadcrumb) }}
        {% endblock %}
        {% block title %}
            {% import "@RoadizRozier/macros/rz_status_badge.html.twig" as rz_status_badge %}
            {% import "@RoadizRozier/macros/rz_badge.html.twig" as rz_badge %}
            <h1 class="rz-page-header__title rz-page-header__item">
                {{ pageTitle }}
            </h1>
            <div class="rz-page-header__item">
                {% include '@RoadizRozier/nodes/nodeTypeCircle.html.twig' %}
            </div>
            <div class="rz-page-header__item--right">
                {{ rz_status_badge.item(node: node) }}
            </div>
        {% endblock %}
        {% block nav_bar %}
            {% include '@RoadizRozier/nodes/navBar.html.twig' with {"current": 'tags'} %}
        {% endblock %}
    {% endembed %}
    <article class="content content-node-edit-tags">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: {id: 'edit-node-tags-form'}}) }}
        {{ form_widget(form) }}
        <fieldset data-uk-margin>
            <button is="rz-save-button" data-action-save="#edit-node-tags-form" class="uk-button uk-button-success" type="submit">
                <span class="icon-container"><i class="uk-icon-rz-save-mini"></i></span>
                <span class="label"><span class="label-text">{% trans %}save{% endtrans %}</span></span>
            </button>
        </fieldset>
        {{ form_end(form) }}
    </article>
    {% include '@RoadizRozier/nodes/actionsMenu.html.twig' %}
</section>
{% endblock %}
