{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {%- if is_granted('ROLE_ACCESS_CUSTOMFORMS_DELETE') and field.id -%}
            {{ _self.item(
                label: 'delete.customFormField',
                class: 'rz-button--error',
                href: path('customFormFieldsDeletePage', { customFormFieldId: field.id}),
                icon: 'rz-icon-ri--delete-bin-7-line'
            ) }}
        {%- endif -%}
    {% endblock %}
{% endembed %}
