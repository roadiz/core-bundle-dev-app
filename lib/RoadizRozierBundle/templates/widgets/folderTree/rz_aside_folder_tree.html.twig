{% set head_button = null %}

{% if folderTree is defined %}
    {% set head_button = {
        icon: 'rz-icon-ri--add-line',
        label: folderTree.getRootFolder == null ? 'add.a.folder'|trans : 'add.child.folder'|trans,
        id: 'foldertree-btn-add',
        attributes: {
            href: folderTree.getRootFolder == null ?
                path('foldersAddPage')
                : path('foldersAddChildPage', { folderId : folderTree.rootFolder.id }),
        }
    } %}
{% endif %}

{% embed '@RoadizRozier/widgets/rz_tree_wrapper.html.twig' with {
    root_classes: root_classes|default([])|merge(['rz-folder-tree', 'foldertree-widget']),
    title: 'folderTree'|trans,
    has_header: mainFolderTree,
    display_translations: mainFolderTree,
    head_button: head_button,
    tree: folderTree,
    mainFolderTree: mainFolderTree,
} only %}

	{% block language_switcher %}
        {% if mainFolderTree %}
            {% include '@RoadizRozier/widgets/rz_language_switcher.html.twig' with {
                tree: tree,
                classes: ['rz-aside__langs', 'foldertree-langs'],
            } only %}
        {% endif %}
	{% endblock %}

    {% block tree_content %}
        {% include '@RoadizRozier/widgets/folderTree/folderTree.html.twig' with {
            folderTree: tree,
            mainFolderTree: mainFolderTree,
        } only %}
    {% endblock %}

{% endembed %}
