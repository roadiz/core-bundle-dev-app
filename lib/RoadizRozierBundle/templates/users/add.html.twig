{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {% trans %}add.a.user{% endtrans %}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global add-user">

    <header class="content-header header-user header-user-edit">
        <h1 class="content-title user-add-title">{% trans %}add.a.user{% endtrans %}</h1>
        <a class="content-header-nav-back uk-navbar-content"
           href="{{ path('usersHomePage') }}"
           title="{% trans %}back_to.users{% endtrans %}"
           data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
    </header>

    <article class="content content-add">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: {id: 'add-user-form'}}) }}
            {{ form_widget(form) }}
            {% import "@RoadizRozier/macros/rz_floating_bar.html.twig" as floating_bar  %}
            {{ floating_bar.saveItem('#add-user-form') }}
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/users/actionsMenu.html.twig' %}
</section>
{% endblock %}
