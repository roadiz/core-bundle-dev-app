{% embed '@RoadizRozier/widgets/rz_tree_wrapper.html.twig' with {
    title: 'aside.folder_tree.title'|trans,
    tree: folderTree,
    mainFolderTree: mainFolderTree,
    tree_type: 'folder',
} only %}
    {% block head_button %}
        {% set href = null %}
        {% if folderTree is defined and folderTree.getRootFolder == null  %}
            {% set href = path('foldersAddPage') %}
        {% elseif folderTree is defined %}
            {% set href = path('foldersAddChildPage', { folderId : folderTree.rootFolder.id }) %}
        {% endif %}

        {{ _self.add_button({
            label: folderTree is defined and folderTree.getRootFolder == null ? 'add.a.folder'|trans : 'add.child.folder'|trans,
            id: 'foldertree-btn-add',
            attributes: {
                href: href
            }
        }) }}
    {% endblock %}

    {% block tree_content %}
        {% if folderTree is defined  %}
            {% include '@RoadizRozier/widgets/folderTree/folderTree.html.twig' with {
                folderTree: tree,
                mainFolderTree: mainFolderTree,
            } only %}
        {% else %}
            {{ parent() }}
        {% endif %}
    {% endblock %}
{% endembed %}
