{% extends '@RoadizRozier/layout.html.twig' %}
{% import "@RoadizRozier/macros/rz_button.html.twig" as rz_button %}

{% block title %}{% trans %}two_factor_authentication{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
    <section class="content-global">
        {% include '@RoadizRozier/admin/head.html.twig' with {
            title: 'two_factor_authentication'|trans,
            subtitle: 'start_two_factor_activation'|trans,
            breadcrumb: {
                label: 'two-factor-breadcrumb',
                current: 'two_factor_authentication'|trans,
            }
        } only %}

        <article class="content content-delete content-no-action-menu">
            {% if form %}
                {% form_theme form '@RoadizRozier/forms.html.twig' %}
                {{ form_start(form) }}
                {{ form_widget(form) }}
                <div class="rz-message rz-form-field__message">
                    <p class="rz-message__text">
                        {% trans %}are_you_sure.activate.two_factor{% endtrans %}
                    </p>
                </div>
                <div class="rz-button-group rz-button-group--gap-md">
                    {{
                        rz_button.root({
                            tagName: 'a',
                            attributes: {
                                href:  path('usersHomePage'),
                            },
                            emphasis: 'secondary',
                            label: 'cancel',
                            icon: 'rz-icon-ri--corner-down-left-line',
                        })
                    }}
                    {{
                        rz_button.root({
                            attributes: {
                                type: 'submit',
                            },
                            emphasis: 'primary',
                            label: 'begin_activation'|trans,
                            icon: 'rz-icon-ri--arrow-drop-right-line',
                        })
                    }}
                </div>
                {{ form_end(form) }}
            {% elseif displayQrCodeTotp %}
                <h2>{% trans %}scan_qr_code_with_totp_app{% endtrans %}</h2>
                <p><img alt="Two factor QRCode" width="256" height="256" src="{{ path("2fa_qr_code_totp") }}" /></p>
                <h2>{% trans %}enter_generated_code_to_finalize{% endtrans %}</h2>
                {% form_theme totpForm '@RoadizRozier/forms.html.twig' %}
                {{ form_start(totpForm) }}
                {{ form_widget(totpForm) }}
                <div class="rz-form-field rz-form-field--align-start">
                    {{
                        rz_button.root({
                            attributes: {
                                type: 'submit',
                            },
                            emphasis: 'primary',
                            label: 'submit_totp_code',
                            icon: 'rz-icon-ri--arrow-drop-right-line',
                        })
                    }}
                </div>
                {{ form_end(totpForm) }}
            {% else %}
                <div>
                    <p class="uk-alert uk-alert-success">
                        {% trans %}two_factor_authentication_is_enabled{% endtrans %}
                    </p>
                    <div class="rz-message rz-form-field__message">
                        <p class="rz-message__text">
                            {% trans %}two_factor_authentication_is_enabled{% endtrans %}
                        </p>
                    </div>
                    <div class="rz-button-group rz-button-group--gap-md">
                        {{
                            rz_button.root({
                                tagName: 'a',
                                attributes: {
                                    href:  path('2fa_admin_two_factor_backup_codes'),
                                },
                                emphasis: 'secondary',
                                label: 'generate_backup_codes',
                                icon: 'rz-icon-ri--corner-down-left-line',
                            })
                        }}
                        {{
                            rz_button.root({
                                tagName: 'a',
                                attributes: {
                                    href:  path('2fa_admin_two_factor_disable'),
                                },
                                emphasis: 'primary',
                                color: 'danger',
                                label: 'disable_two_factor_authentication',
                                icon: 'rz-icon-ri--lock-2-line',
                            })
                        }}
                    </div>
                </div>
            {% endif %}
        </article>
    </section>
{% endblock %}
