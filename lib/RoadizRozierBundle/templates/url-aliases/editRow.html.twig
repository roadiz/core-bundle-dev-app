<tr class="{% if loop.index0 is odd %}odd{% endif %}">
    <td>
        {# Update URL alias #}
        {% form_theme urlAlias.editForm '@RoadizRozier/horizontalForms.html.twig' %}
        {{ form_start(urlAlias.editForm, {
            attr: { class: "urlalias-form rz-form--align-end" }
        }) }}
            {{ form_widget(urlAlias.editForm) }}
            {% import '@RoadizRozier/macros/rz_button.html.twig' as rz_button %}
            {{ rz_button.root({
                icon: 'rz-icon-ri--edit-line',
                label: 'edit'|trans,
                attributes: {
                    type: 'submit',
                    value: 'edit'|trans,
                }
            }) }}
        {{ form_end(urlAlias.editForm) }}
    </td>
    <td>{{ urlAlias.alias.getNodeSource.getTranslation.getName }}</td>
    {% if actions_available %}
        <td>
            {# Delete URL Alias #}
            {% embed '@RoadizRozier/includes/rz_table_actions.html.twig' %}
                {% block other_actions %}
                    {% form_theme urlAlias.deleteForm '@RoadizRozier/forms.html.twig' %}
                    {{ form_start(urlAlias.deleteForm) }}
                        {{ form_widget(urlAlias.deleteForm) }}
                        {% import '@RoadizRozier/macros/rz_table_action.html.twig' as rz_table_action %}
                        {{ rz_table_action.item({
                            icon: 'rz-icon-ri--delete-bin-7-line',
                            color: 'danger',
                            attributes: {
                                type: 'submit',
                                title: 'delete'|trans,
                            }
                        }) }}
                    {{ form_end(urlAlias.deleteForm) }}
                {% endblock %}
            {% endembed %}
        </td>
    {% endif %}
</tr>
