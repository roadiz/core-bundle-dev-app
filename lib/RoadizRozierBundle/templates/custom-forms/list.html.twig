{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}customForms{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<rz-bulk-section>
    {% include '@RoadizRozier/custom-forms/head.html.twig' with {
        title: 'customForms'|trans,
        filters: filters,
        buttons: [{
            label: 'add.a.customForm'|trans,
            href: path('customFormsAddPage'),
            icon: 'rz-icon-ri--add-line',
        }]
    } only %}

    {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: true,
    }  only %}
    {% include '@RoadizRozier/admin/bulk_actions.html.twig' %}
    <article class="content content-no-action-menu content-node-types-list">
        <div class="content-table-cont">
            <table class="content-table custom-forms uk-table">
                <thead>
                    <tr>
                        {%- include '@RoadizRozier/custom-forms/customform_row_header.html.twig' -%}
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        <tr>
                            {% include '@RoadizRozier/custom-forms/customform_row.html.twig' %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </article>
</rz-bulk-section>
{% endblock %}
