{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if item.id and is_granted('ROLE_ACCESS_WEBHOOKS') %}
            {{ _self.item(
                label: 'webhook.trigger',
                href: path('webhooksTriggerPage', { id: item.id }),
                icon: 'rz-icon-ri--space-ship-line'
            ) }}
            {{ _self.item(
                label: 'delete',
                class: 'rz-button--error',
                href: path('webhooksDeletePage', { id: item.id}),
                icon: 'rz-icon-ri--delete-bin-7-line'
            ) }}
        {% endif %}
    {% endblock %}
{% endembed %}
