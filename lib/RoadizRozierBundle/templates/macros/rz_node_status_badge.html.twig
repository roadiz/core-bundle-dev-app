
{% macro get_list(node, options = { display_label: true }) %}
 {% import "@RoadizRozier/macros/rz_status_badge.html.twig" as rz_status_badge %}
    {% set items = [] %}

    {% if node.isDeleted %}
        {% set items = items|merge([ rz_status_badge.item('deleted', options.display_label) ]) %}
    {% endif %}
    {% if node.isDraft == true %}
        {% set items = items|merge([ rz_status_badge.item('draft', options.display_label) ]) %}
    {% endif %}
    {% if node.isPublished == true %}
        {% set items = items|merge([ rz_status_badge.item('published', options.display_label) ]) %}
    {% endif %}
    {% if node.isPending == true %}
        {% set items = items|merge([ rz_status_badge.item('pending', options.display_label) ]) %}
    {% endif %}
    {% if node.isLocked == true %}
        {% set items = items|merge([ rz_status_badge.item('locked', options.display_label) ]) %}
    {% endif %}
    {% if node.isArchived == true %}
        {% set items = items|merge([ rz_status_badge.item('archived', options.display_label) ]) %}
    {% endif %}
    {% if node.isShadow == true %}
        {% set items = items|merge([ rz_status_badge.item('shadow', options.display_label) ]) %}
    {% endif %}
    {% if node.isVisible == false %}
        {% set items = items|merge([ rz_status_badge.item('hidden', options.display_label) ]) %}
    {% endif %}
    {% if node.isHidingChildren == true %}
        {% set items = items|merge([ rz_status_badge.item('hiding-children', options.display_label) ]) %}
    {% endif %}

    {{ items|join('|||')|raw }}
{% endmacro %}

{% macro main_badge(node, options = { display_label: true }) %}
    {{ _self.get_list(node, options)|split('|||')|first|raw }}
{% endmacro %}


{% macro all_badges(node, options = { display_label: true }) %}
    {{ _self.get_list(node, options)|split('|||')|join(' ')|raw }}
{% endmacro %}
