{% embed "@RoadizRozier/macros/rz_page_header.html.twig" %}
    {% block breadcrumb %}
        {# Override in specific templates if breadcrumb is needed #}
    {% endblock %}

    {% block buttons %}
        {% if buttons is defined %}
            <div class="rz-button-group--gap-md rz-page-header__item--right">
                {{ buttons|raw }}
            </div>
        {% endif %}
    {% endblock %}

    {% block badges %}
        {# Override in specific templates if badges are needed #}
    {% endblock %}

    {% block translation %}
        {# Override in specific templates if translation bar is needed #}
    {% endblock %}

    {% block title %}
        <h1 class="rz-page-header__title rz-page-header__item">
            {{ title }}
        </h1>
    {% endblock %}

    {% block subtitle %}
        {# Override in specific templates if subtitle is needed #}
    {% endblock %}

    {% block nav_bar %}
        {% if with_nav_bar is defined and with_nav_bar and user is defined %}
            {% include '@RoadizRozier/users/navBar.html.twig' with {'user': user, current: current} %}
        {% endif %}
    {% endblock %}
{% endembed %}
