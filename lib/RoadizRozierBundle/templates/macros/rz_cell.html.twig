
{% macro input(options = {}) %}
    {% import '@RoadizRozier/macros/element_attributes.html.twig' as el_attr %}

    {% set tagName = options.tagName|default('td') %}

    <{{ tagName }}
        {{ el_attr.print(options.attributes|default({})) }}
    >
        <input
            is="rz-input"
            type="checkbox"
            {{ el_attr.print(options.input|default({})) }}
        />
    </{{ tagName }}>
{% endmacro %}

{% macro selection_all_input(options = {}) %}
    {% set inputOptions = options.input|default({})|merge({
        name: 'bulk-selection-all',
        'aria-label': "select.all"|trans,
        }) %}
    {{
        _self.input(options|merge({ input: inputOptions })
    )}}
{% endmacro %}

{% macro selection_input(options = {}) %}
    {% set inputOptions = options.input|default({})|merge({
        name: 'bulk-selection[]',
        'aria-label': "select.row"|trans,
        }) %}
    {{
        _self.input(options|merge({ input: inputOptions })
    )}}
{% endmacro %}
