{%- if folderTree -%}
    <ul class="rz-tree__list root-tree"
        data-parent-folder-id="{{ folder.getId }}">
        {% for cfolder in folderTree.folders %}
            {% include '@RoadizRozier/widgets/folderTree/singleFolder.html.twig' with {
                "folder": cfolder,
                "folderTree": folderTree
            } only %}
        {% endfor %}
    </ul>
{%- endif -%}
