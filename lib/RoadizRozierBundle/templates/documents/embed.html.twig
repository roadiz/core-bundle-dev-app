{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}embed.document{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global embed-document">
    {% include '@RoadizRozier/documents/head.html.twig' with {
        title: "embed.document"|trans,
    } only %}

    <article class="content content-embed">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: {id: "embed-dropzone-document"}}) }}
        {{ form_widget(form) }}
        <fieldset data-uk-margin>
            <button is="rz-save-button" data-action-save="#embed-dropzone-document" class="uk-button uk-button-success" type="submit">
                <span class="icon-container"><i class="uk-icon-rz-upload"></i></span>
                <span class="label"><span class="label-text">{% trans %}embed{% endtrans %}</span></span>
            </button>
        </fieldset>
        {{ form_end(form) }}
    </article>
</section>
{% endblock %}
