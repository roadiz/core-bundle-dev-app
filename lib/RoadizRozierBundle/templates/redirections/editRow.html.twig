{% import '@RoadizRozier/macros/rz_button.html.twig' as rz_button %}

<tr class="{% if loop.index0 is odd %}odd{% endif %}">
    <td>
        {# Update URL alias #}
        {% form_theme redirection.editForm '@RoadizRozier/horizontalForms.html.twig' %}
        {{ form_start(redirection.editForm, {
            attr: { class: "redirection-form rz-form--align-end" }
        }) }}
            {{ form_widget(redirection.editForm) }}
            {{ rz_button.root({
                icon: 'rz-icon-ri--edit-line',
                label: 'edit'|trans,
                attributes: {
                    type: 'submit',
                    value: 'edit'|trans,
                }
            }) }}
        {{ form_end(redirection.editForm) }}
    </td>
    <td>{{ path(redirection.redirection.redirectNodeSource) }}</td>
    <td>{{ redirection.redirection.redirectNodeSource.translation.name }}</td>
    <td>
        {# Delete URL Alias #}
        {% embed '@RoadizRozier/includes/rz_table_actions.html.twig' %}
            {% block other_actions %}
                {% import '@RoadizRozier/macros/rz_table_action.html.twig' as rz_table_action %}
                {% form_theme redirection.deleteForm '@RoadizRozier/forms.html.twig' %}
                {{ form_start(redirection.deleteForm) }}
                    {{ form_widget(redirection.deleteForm) }}
                    {{ rz_table_action.item({
                        icon: 'rz-button__icon rz-icon-ri--delete-bin-7-line',
                        color: 'danger',
                        attributes: {
                            type: 'submit',
                            value: 'delete'|trans,
                            title: 'attributes.reset_value'|trans,
                        }
                    }) }}
                {{ form_end(redirection.deleteForm) }}
            {% endblock %}
        {% endembed %}
    </td>
</tr>
