{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}webhooks{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<rz-bulk-section>
    {% include '@RoadizRozier/admin/head.html.twig' with {
        title: 'webhooks'|trans,
        filters: filters,
        buttons: [{
            label: 'add.a.webhook'|trans,
            href: path('webhooksAddPage'),
            icon: 'rz-icon-ri--add-line'
        }]
    } only %}

    {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: true,
    }  only %}
    {% include '@RoadizRozier/admin/bulk_actions.html.twig' %}

    <article>
        {% include '@RoadizRozier/admin/webhooks/webhook_table.html.twig' with {
            selection_available: hasBulkActions,
            actions_available: true,
        } %}
    </article>
</rz-bulk-section>
{% endblock %}
