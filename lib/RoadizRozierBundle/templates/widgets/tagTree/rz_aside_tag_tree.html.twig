{% set head_button = null %}
{% if tagTree is defined %}
    {% set head_button = {
        icon: 'rz-icon-ri--add-line',
        label: tagTree.getRootTag == null ? 'add.a.tag'|trans : 'add.child.tag'|trans,
        attributes: {
            href: tagTree.getRootTag == null ?
                path('tagsAddPage')
                : path('tagsAddChildPage', { tagId : tagTree.rootTag.id }),
        }
    } %}
{% endif %}

{% embed '@RoadizRozier/widgets/rz_tree_wrapper.html.twig' with {
    root_classes: root_classes|default([])|merge(['rz-tag-tree', 'tagtree-widget']),
    title: 'tagTree'|trans,
    has_header: mainTagTree,
    display_translations: mainTagTree,
    head_button: head_button,
    tree: tagTree,
    mainTagTree: mainTagTree
} only %}

    {% block language_switcher %}
        {% if mainTagTree %}
            {% include '@RoadizRozier/widgets/rz_language_switcher.html.twig' with {
                tree: tree,
                classes: ['rz-aside__langs', 'tagtree-langs'],
            } only %}
            {% endif %}
	{% endblock %}

    {% block tree_content %}
        {% include '@RoadizRozier/widgets/tagTree/tagTree.html.twig' with {
            tagTree: tree,
            mainTagTree: mainTagTree,
        } only %}
    {% endblock %}

{% endembed %}
