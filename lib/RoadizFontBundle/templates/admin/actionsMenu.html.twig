{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if item.id %}
            {{ _self.item(
                label: 'download',
                class: 'rz-button--tertiary',
                href: path('fontsDownloadPage', { id: item.id }),
                icon: 'rz-icon-ri--download-cloud-2-line'
            ) }}
            {{ _self.item(
                label: 'delete',
                class: 'rz-button--error',
                href: path('fontsDeletePage', { id: item.id}),
                icon: 'rz-icon-ri--delete-bin-7-line'
            ) }}
        {% endif %}
    {% endblock %}
{% endembed %}
