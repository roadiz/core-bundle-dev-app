{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if item.id %}
            {% if is_granted('ROLE_ACCESS_ATTRIBUTES_DELETE') %}
                {{ _self.item(
                    label: 'delete',
                    class: 'rz-button--error',
                    href: path('attributeGroupsDeletePage', { id: item.id}),
                    icon: 'rz-icon-ri--delete-bin-7-line'
                ) }}
            {% endif %}
        {% endif %}
    {% endblock %}
{% endembed %}
