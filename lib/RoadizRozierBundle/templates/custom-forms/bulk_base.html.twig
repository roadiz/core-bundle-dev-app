{% extends '@RoadizRozier/admin/base.html.twig' %}

{% block title %}{{ block('bulk_title') }} | {{ parent() }}{% endblock %}

{%- block header -%}
    {% include '@RoadizRozier/admin/head.html.twig' with {
        title: block('bulk_title')|trans,
        filters: filters,
    } only %}
{%- endblock -%}

{% block content_body %}
    <article>
        {% block bulk_form %}{% endblock %}

        {% include '@RoadizRozier/custom-forms/list_table.html.twig' with {
            selection_available: false,
            actions_available: false,
        } %}
    </article>
{% endblock %}
