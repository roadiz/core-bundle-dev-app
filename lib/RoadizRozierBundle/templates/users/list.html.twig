{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}users{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
    <rz-bulk-section>
        {% include '@RoadizRozier/users/head.html.twig' with {
            title: 'users'|trans,
            filters: filters,
            buttons: [{
                label: 'add.a.user'|trans,
                href: path('usersAddPage'),
                icon: 'rz-icon-ri--add-line',
            }],
        } only %}

        {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: false,
        }  only %}
        {% include '@RoadizRozier/users/bulkActions.html.twig' with {
            delete_form_data: bulkDeleteForm|default(null),
            delete_form_action: path('usersBulkDeletePage'),
            delete_form_method: 'GET',
            bulkEnableForm: bulkEnableForm,
            bulkDisableForm: bulkDisableForm,
        } only %}
        <article class="content content-no-action-menu">
            <div class="content-table-cont">
                <table class="content-table users uk-table">
                    <thead>
                    <tr>
                        {% include '@RoadizRozier/users/user_row_header.html.twig' %}
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            {% include '@RoadizRozier/users/user_row.html.twig' %}
                        </tr>
                    {% else %}
                        <tr><td colspan="7">{% trans %}no_users{% endtrans %}</td></tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </article>
    </rz-bulk-section>
{% endblock %}
