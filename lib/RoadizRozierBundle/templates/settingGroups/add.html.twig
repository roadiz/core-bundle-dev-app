{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {% trans %}add.a.settingGroup{% endtrans %}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global">

<header class="content-header header-settingGroup header-settingGroup-add">
       <h1 class="content-title settingGroup-list-title">{% trans %}add.a.settingGroup{% endtrans %}</h1>
       <a class="content-header-nav-back uk-navbar-content"
          href="{{ path('settingGroupsHomePage') }}"
          title="{% trans %}back_to.settingGroups{% endtrans %}"
          data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
    </header>

    <article class="content content-settingGroup-add">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: { id: 'add-settingGroup-form'}}) }}
            {{ form_widget(form) }}
            {% import "@RoadizRozier/macros/rz_actions_menu.html.twig" as floating_bar %}
            {{ floating_bar.saveItem('#add-settingGroup-form') }}
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/settingGroups/actionsMenu.html.twig' %}
</section>
{% endblock %}
