{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if is_granted('ROLE_ACCESS_TRANSLATIONS') and translation.id and not translation.isDefaultTranslation %}
            {{ _self.item(
                label: 'delete',
                class: 'rz-button--error',
                href: path('translationsDeletePage', { translationId: translation.id}),
                icon: 'rz-icon-ri--delete-bin-7-line'
            ) }}
        {% endif %}
    {% endblock %}
{% endembed %}
