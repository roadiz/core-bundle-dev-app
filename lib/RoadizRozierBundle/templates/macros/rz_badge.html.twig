{% macro item(label, icon, size, color, href, onlyIcon = false) %}
    {% if href is defined and href %}
        <a class="rz-badge
           {{ size is defined and size ? ' rz-badge--'~size : '' }}
           {{ color is defined and color ? ' rz-badge--'~color : '' }}"
           {{ label is defined and label ? 'title='~label|trans : '' }}
        >
            {{ _self.inner_item(label, icon, onlyIcon) }}
        </a>
    {% else %}
        <div class="rz-badge
            {{ size is defined and size ? ' rz-badge--'~size : '' }}
            {{ color is defined and color ? ' rz-badge--'~color : '' }}">
            {{ _self.inner_item(label, icon, onlyIcon) }}
        </div>
    {% endif %}
{% endmacro %}

{% macro inner_item(label, icon, onlyIcon) %}
    {% if icon is defined and icon %}
        <span class="rz-badge__icon {{ icon }}"></span>
    {% endif %}
    {% if label is defined and label and not onlyIcon %}
        <span class="rz-badge__label">{{- label|trans -}}</span>
    {% endif %}
{% endmacro %}
