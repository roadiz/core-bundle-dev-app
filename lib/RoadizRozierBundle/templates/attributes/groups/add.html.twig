{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}add.a.attribute_group{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global add-item">
    <header class="content-header header-item header-item-add">
        <h1 class="content-title item-add-title">{% trans %}add.a.attribute_group{% endtrans %}</h1>
        <a class="content-header-nav-back uk-navbar-content" href="{{ path('attributeGroupsHomePage') }}" title="{% trans %}back_to.attribute_groups{% endtrans %}" data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
    </header>

    <article class="content content-add">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: { id: "add-attribute-group-form" }}) }}
            {{ form_widget(form) }}
            {% import "@RoadizRozier/macros/rz_actions_menu.html.twig" as actions_menu %}
            {{ actions_menu.saveItem('#add-attribute-group-form') }}
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/attributes/groups/actionsMenu.html.twig' with {"item": item} only %}
</section>
{% endblock %}
