{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {{ "edit.user.%name%.roles"|trans({'%name%': user.username })|truncate_title }}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global edit-user">
    {% include '@RoadizRozier/users/head.html.twig' with {
        title: "edit.user.%name%.roles"|trans({'%name%': user.username })|truncate_title(40),
        with_nav_bar: true,
        user: user,
        current: 'roles'
    } only %}
    <article class="content content-user-roles">
        <div class="content-table-cont">
            <table class="content-table users--inherited-roles uk-table">
                <thead>
                    <tr>
                        <th>{% trans %}inherited.roles{% endtrans %}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for role in user.roles %}
                    <tr>
                        <td>{{ role }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <hr />
        <div class="content-table-cont">
            <table class="content-table users-roles uk-table">
                <thead>
                    <tr>
                        <th>{% trans %}specific.roles{% endtrans %}</th>
                        <th class="table-actions-row table-actions-row-3">{% trans %}actions{% endtrans %}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for role in user.userRoles %}
                    <tr>
                        <td>{{ role }}</td>
                        <td class="table-actions-row table-actions-row-3">
                            {% if is_granted(role) %}
                                <a
                                    is="rz-link"
                                    href="{{ path('usersRemoveRolesPage', { userId: user.id, role: role }) }}"
                                    tooltip-text="{% trans %}remove{% endtrans %}"
                                    popover-placement="top"
                                    popover-offset="4"
                                    class="rz-button rz-button--primary rz-button--danger"
                                >
                                    <span class="rz-button__icon rz-icon-ri--delete-bin-7-line"></span>
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <hr />
        <h2>{% trans %}add.a.specific.role{% endtrans %}</h2>

        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="rz-form-field rz-form-field--align-start">
                <button class="rz-button rz-button--primary" type="submit">
                    <span class="rz-button__label">{% trans %}add.role{% endtrans %}</span>
                    <span class="rz-button__icon rz-icon-ri--add-line"></span>
                </button>
            </div>
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/users/actionsMenu.html.twig' %}
</section>
{% endblock %}
