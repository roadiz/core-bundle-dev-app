{% embed "@RoadizRozier/macros/rz_actions_menu.html.twig" with {
    vertical: true,
    class: 'actions-menu',
    item: item
} only %}
    {% block items %}
        {% if item.id %}
            {{ _self.item(
                label: 'download',
                class: 'rz-button--tertiary',
                href: path('fontsDownloadPage', { id: item.id }),
                icon: 'rz-icon-ri--download-cloud-2-line'
            ) }}
            {{ _self.deleteItem(href: path('fontsDeletePage', { id: item.id })) }}
        {% endif %}
    {% endblock %}
{% endembed %}
