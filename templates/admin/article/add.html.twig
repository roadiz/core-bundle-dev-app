{% extends "@RoadizRozier/admin/base.html.twig" %}

{%- block header -%}
    {% include '@RoadizRozier/admin/head.html.twig' with {
        title: 'articles.add'|trans,
    } only %}
{%- endblock -%}

{%- block content_body -%}
    <article class="content">
        {%- block content_body_before -%}{%- endblock -%}
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, {
            'attr': {
                'id': 'articles-form',
                'class': 'uk-form uk-form-stacked'
            }
        }) }}{{ form_widget(form) }}
        <fieldset data-uk-margin>
            {% apply spaceless %}
                <button data-action-save="#articles-form"
                        class="uk-button uk-button-primary rz-action-save" type="submit">
                    <span class="icon-container"><i class="uk-icon-rz-save"></i></span>
                    <span class="label"><span class="label-text">{% block content_form_submit_label %}
                                {%- trans -%}articles.form.add{%- endtrans -%}
                            {% endblock %}</span></span>
                </button>
            {% endapply %}
        </fieldset>
        {{ form_end(form) }}
        {%- block content_body_after -%}{%- endblock -%}
    </article>
{%- endblock -%}
