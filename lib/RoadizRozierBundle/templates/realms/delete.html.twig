{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{{ "delete.realm.%name%"|trans({'%name%': item.name}) }} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global">
    {% include '@RoadizRozier/realms/head.html.twig' with {
        title: "delete.realm.%name%"|trans({'%name%': item.name})
    } only %}

    <article class="content content-delete content-no-action-menu">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form) }}
        {{ form_widget(form) }}
        <fieldset data-uk-margin>
            <legend class="uk-alert uk-alert-danger"><i class="uk-icon uk-icon-warning"></i> {% trans %}are_you_sure.delete.realm{% endtrans %}</legend>
            <a href="{{ path('realmsHomePage') }}"
               class="uk-button"><i class="uk-icon-rz-back-parent"></i> {% trans %}cancel{% endtrans %}</a>
            <button class="uk-button uk-button-danger" type="submit">
                <span class="icon-container"><i class="uk-icon-rz-trash-o"></i></span>
                <span class="label"><span class="label-text">{% trans %}delete{% endtrans %}</span></span>
            </button>
        </fieldset>
        {{ form_end(form) }}
    </article>
</section>
{% endblock %}
