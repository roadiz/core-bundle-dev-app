<div class="rz-page-header content-header">
    <div class="rz-page-header__row">
        {% block translation %}
        {% endblock %}
        {% block breadcrumb %}
        {% endblock %}
        {% block buttons %}
        {% endblock %}
    </div>
    <div class="rz-page-header__row">
        {% block title %}
            <h1 class="rz-page-header__title rz-page-header__item">{{ title }}</h1>
        {% endblock %}
    </div>
    <div class="rz-page-header__row">
        {% block nav_bar %}
        {% endblock %}
    </div>
    {% block additional_row %}
    {% endblock %}
</div>

{% macro breadcrumb(breadcrumb) %}
    <nav class="rz-breadcrumb" aria-label="{{ breadcrumb.label }}">
        <ol class="rz-breadcrumb__list">
            {% for parent in breadcrumb.parent %}
                {% if is_granted('READ', parent) %}
                    {% set breadcrumbsItem = getBreadcrumbsItem(parent) %}
                    <li class="rz-breadcrumb__list-item">
                        <a class="rz-breadcrumb__item" href="{{ breadcrumbsItem.url }}">
                            {%- if breadcrumbsItem.isHome -%}
                                <span class="rz-button__icon rz-icon-ri--home-2-line"></span>
                            {%- endif -%}
                            {{- breadcrumbsItem.label|u.truncate(25, '[…]', true) -}}
                        </a>
                    </li>
                {% endif %}
            {% endfor %}
            <li class="rz-breadcrumb__list-item">
                <a class="rz-breadcrumb__item" aria-current="page">{{ breadcrumb.current }}</a>
            </li>
        </ol>
    </nav>
{% endmacro %}
