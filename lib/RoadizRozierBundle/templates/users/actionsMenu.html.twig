{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if is_granted('ROLE_ACCESS_USERS_DELETE') and user.id %}
            {{ _self.item(
                label: 'delete',
                class: 'rz-button--error',
                href: path('usersDeletePage', { id: user.id}),
                icon: 'rz-icon-ri--delete-bin-7-line'
            ) }}
        {% endif %}
    {% endblock %}
{% endembed %}
