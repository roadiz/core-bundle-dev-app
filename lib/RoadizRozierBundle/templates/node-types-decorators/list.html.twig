{% extends "@RoadizRozier/layout.html.twig" %}

{% block title %}{% trans %}nodeTypeDecorator{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
    <section class="bulk-layout content-global content-nav-and-filters">
        {% include '@RoadizRozier/node-types/head.html.twig' with {
            title: 'nodeTypes'|trans,
            filters: filters,
            popover: {
                title: 'add.a.nodeTypeDecorator'|trans,
                icon: 'rz-icon-ri--arrow-drop-down-line',
                items: nodeTypes,
            },
        } only %}

        {% include '@RoadizRozier/widgets/filtersBar.html.twig' %}
        {% include '@RoadizRozier/admin/bulk_actions.html.twig' %}
        <article class="content content-no-action-menu content-node-type-decorator-list">
            <div class="content-table-cont">
                <table class="node-type-decorator content-table uk-table">
                    <thead>
                    <tr>
                        {%- include '@RoadizRozier/node-types-decorators/row_header.html.twig' -%}
                    </tr>
                    </thead>
                    <tbody>
                    {%- for item in items -%}
                        <tr>
                            {%- include '@RoadizRozier/node-types-decorators/row.html.twig' -%}
                        </tr>
                    {%- endfor -%}
                    </tbody>
                </table>
            </div>
        </article>
    </section>
{% endblock %}
