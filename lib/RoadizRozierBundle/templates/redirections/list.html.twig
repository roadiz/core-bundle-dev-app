{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {% trans %}manage.redirections{% endtrans %}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<rz-bulk-section>
    {% include '@RoadizRozier/redirections/head.html.twig' with {
        title: 'manage.redirections'|trans,
        filters: filters,
        buttons: [{
            label: 'add.a.redirection'|trans,
            href: path('redirectionsAddPage'),
            icon: 'rz-icon-ri--add-line'
        }]
    } only %}

    {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: true,
    }  only %}
    {% include '@RoadizRozier/admin/bulk_actions.html.twig' %}
    <article class="content content-no-action-menu content-node-types-list">
        <div class="content-table-cont">
            <table class="content-table redirections uk-table">
                <thead>
                    <tr>
                        {% include '@RoadizRozier/redirections/redirection_row_header.html.twig' %}
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                        <tr>
                            {% include '@RoadizRozier/redirections/redirection_row.html.twig' %}
                        </tr>
                    {% else %}
                        <tr><td colspan="5">{% trans %}no_redirections{% endtrans %}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </article>
</rz-bulk-section>
{% endblock %}
