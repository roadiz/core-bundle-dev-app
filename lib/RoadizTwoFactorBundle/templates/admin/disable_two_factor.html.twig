{% extends '@RoadizRozier/layout.html.twig' %}
{% import "@RoadizRozier/macros/rz_button.html.twig" as rz_button %}

{% set title = 'disable_two_factor_authentication'|trans %}

{% block title %}{{ title|truncate_title }}{% endblock %}

{% block content %}
    <section class="content-global delete-document">
        {% include '@RoadizRozier/admin/head.html.twig' with {
            title: title,
        } only %}

        <article class="content content-delete content-no-action-menu">
            {% form_theme form '@RoadizRozier/forms.html.twig' %}
            {{ form_start(form) }}
            {{ form_widget(form) }}
            <div class="rz-message rz-message--error rz-form-field__message">
                <p class="rz-message__text">
                    {{ 'are_you_sure.disable.two_factor'|trans }}
                </p>
            </div>
            <div class="rz-button-group rz-button-group--gap-md">
                {{
                rz_button.root({
                    tagName: 'a',
                    attributes: {
                        href: path('2fa_admin_two_factor'),
                    },
                    emphasis: 'secondary',
                    label: 'cancel',
                    icon: 'rz-icon-ri--corner-down-left-line',
                })
                }}
                {{
                rz_button.root({
                    attributes: {
                        type: 'submit',
                    },
                    emphasis: 'primary',
                    color: 'danger',
                    label: 'disable_two_factor'|trans,
                })
                }}
            </div>
            {{ form_end(form) }}
        </article>
    </section>
{% endblock %}

