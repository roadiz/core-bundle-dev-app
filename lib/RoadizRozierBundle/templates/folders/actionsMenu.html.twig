<nav data-action-menu class="actions-menu uk-navbar">
    {% if folder.getId %}
    <a class="uk-button rz-no-ajax-link" href="{{ path('foldersDownloadPage', { folderId: folder.getId }) }}">
        <span class="icon-container"><i class="uk-icon-rz-download"></i></span>
        <span class="label"><span class="label-text">{% trans %}download{% endtrans %}</span></span>
    </a>
    {# Delete current folder #}
        {% if not folder.Locked %}
            <a class="uk-button uk-button-danger" href="{{ path('foldersDeletePage', { folderId: folder.getId}) }}">
                <span class="icon-container"><i class="uk-icon-rz-trash-mini-o"></i></span>
                <span class="label"><span class="label-text">{% trans %}delete.folder{% endtrans %}</span></span>
            </a>
        {% endif %}
    {% endif %}
</nav>

{% embed "@RoadizRozier/macros/rz_floating_bar.html.twig" with {
    vertical: true,
    class: 'actions-menu'
} %}
    {% block items %}
        {% if folder.getId %}
            {{ _self.item(
                label: 'download',
                class: 'rz-button--tertiary',
                href: path('foldersDownloadPage', { folderId: folder.getId }),
                icon: 'rz-icon-ri--download-line'
            ) }}

            {% if not folder.Locked %}
                {{ _self.item(
                    label: 'delete.folder',
                    class: 'rz-button--error',
                    href: path('foldersDeletePage', { folderId: folder.getId }),
                    icon: 'rz-icon-ri--delete-bin-7-line'
                ) }}
            {% endif  %}
        {% endif %}
    {% endblock %}
{% endembed %}
