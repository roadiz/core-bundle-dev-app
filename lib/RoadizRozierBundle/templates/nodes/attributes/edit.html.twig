{% set currentTitle = source.title|default(node.nodeName) %}

{% extends '@RoadizRozier/layout.html.twig' %}
{% import "@RoadizRozier/macros/rz_status_badge.html.twig" as rz_status_badge %}

{% block content %}
    <section class="content-global">
        {% include '@RoadizRozier/nodes/head.html.twig' with {
            node: node,
            title: ("edit.nodeSource.%name%"|trans({'%name%': currentTitle}))|u.truncate(30, '[…]', false),
            translation: translation,
            available_translations: available_translations,
            current: 'attributes',
            app: app,
            with_debug_badge: true,
            with_info_badge: true,
            with_status_badge: true,
            with_nav_bar: true,
        } only %}

        <article>
            {% embed '@RoadizRozier/includes/rz_table.html.twig' with {
                display_thead: false,
                sortable: not order_by_weight,
                class: 'attribute-value-forms',
            } %}
                {% block tbody_content %}
                    {% for attribute_value_translation_form in attribute_value_translation_forms %}
                        {% set attributeValue = attribute_value_translation_form.vars.data.attributeValue %}
                        <tr
                            class="setting-row"
                            data-position="{{ attributeValue.position }}"
                            data-id="{{ attributeValue.id }}"
                        >
                            <th class="name attribute-value-col">
                                <span class="color" style="--rz-accent-color: {{ attributeValue.attribute.color|default('transparent') }};"></span>
                                <strong>{{- attribute_value_translation_form.vars.data|attribute_label -}}</strong>
                            </th>
                            <td>
                                {% set _groupLabel = attributeValue.attribute.group|attribute_group_label %}
                                {{- _groupLabel is not empty ? _groupLabel : attributeValue.attribute.group.name -}}
                            </td>
                            <td>
                                {% form_theme attribute_value_translation_form '@RoadizRozier/horizontalForms.html.twig' %}
                                {{ form_start(attribute_value_translation_form, {
                                    'attr': {
                                        'class': 'rz-form'
                                    }
                                }) }}
                                    {{ form_widget(attribute_value_translation_form) }}
                                    <button
                                        class="rz-button"
                                        title="{% trans %}edit{% endtrans %}"
                                        type="submit"
                                        style="display: none"
                                    >
                                        <span class="rz-button__icon rz-icon-ri--arrow-drop-right-line"></span>
                                    </button>
                                {{ form_end(attribute_value_translation_form) }}
                            </td>
                            <td class="table-actions-row">
                                <div class="rz-button-group rz-button-group--md rz-button-group--end">
                                        <a
                                            is="rz-link"
                                            class="rz-button rz-button--primary rz-button--success rz-button-group__button rz-button-settings-save"
                                            href="#{{ attribute_value_translation_form.vars.id }}"
                                            title="{% trans %}save{% endtrans %}"
                                        >
                                            <span class="rz-button__icon rz-icon-ri--save-line"></span>
                                        </a>
                                    {% if translation and attributeValue.attributeValueTranslations.count > 1 %}
                                        <a
                                            is="rz-link"
                                            class="rz-button rz-button--secondary rz-button-group__button"
                                            href="{{ path('nodesResetAttributesPage', {
                                                nodeId : node.id,
                                                translationId : translation.id,
                                                attributeValueId : attributeValue.id
                                            }) }}"
                                            title="{% trans %}attributes.reset_value{% endtrans %}"
                                        >
                                            <span class="rz-button__icon rz-icon-ri--reset-left-line"></span>
                                        </a>
                                    {% endif %}
                                    {% if translation and (translation.defaultTranslation or attributeValue.attributeValueTranslations.count == 1) %}
                                        <a
                                            is="rz-link"
                                            class="rz-button rz-button--primary rz-button--danger rz-button-group__button"
                                            href="{{ path('nodesDeleteAttributesPage', {
                                                nodeId : node.id,
                                                translationId : translation.id,
                                                attributeValueId : attributeValue.id
                                            }) }}"
                                            title="{% trans %}attributes.delete_value{% endtrans %}"
                                        >
                                            <span class="rz-button__icon rz-icon-ri--delete-bin-7-line"></span>
                                        </a>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% endblock %}
            {% endembed %}

            {% if addAttributeForm %}
                {% form_theme addAttributeForm '@RoadizRozier/horizontalForms.html.twig' %}
                {{ form_start(addAttributeForm, {
                    'attr': {
                        'id': 'add-node-attribute-form',
                        'class': 'rz-form'
                    }
                }) }}
                {{ form_widget(addAttributeForm) }}
                <div class="rz-form-field rz-form-field--justify-end rz-form-field--align-end">
                    <button type="submit" class="rz-button rz-button--primary">
                        <span class="rz-button__label">{% trans %}add.a.node.attribute{% endtrans %}</span>
                        <span class="rz-button__icon rz-icon-ri--add-large-line"></span>
                    </button>
                </div>
                {{ form_end(addAttributeForm) }}
            {% endif %}
            <hr>

            {% set currentPath = path('nodesEditAttributesPage', {
                nodeId: node.id,
                translationId: translation.id
            })  %}

            <a
                class="rz-button rz-button--secondary"
                href="{{ path('attributesAddPage', {referer: currentPath}) }}"
            >
                <span class="rz-button__label">{% trans %}add.a.attribute{%- endtrans -%}</span>
                <span class="rz-button__icon rz-icon-ri--add-large-line"></span>
            </a>
        </article>

        {% include '@RoadizRozier/nodes/actionsMenu.html.twig' %}
    </section>
{% endblock %}
