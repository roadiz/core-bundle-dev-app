{% embed "@RoadizRozier/macros/rz_page_header.html.twig" %}
    {% block buttons %}
        {% if displayButtonAction is defined and displayButtonAction %}
            <div class="rz-button-group--gap-md rz-page-header__item--right">
                <a class="rz-button rz-button--primary rz-button-group__button"
                   href="{{ path('settingsAddPage') }}">
                    <span class="rz-button__label">{{ 'add.a.setting'|trans }}</span>
                    <span class="rz-button__icon rz-icon-ri--add-line"></span>
                </a>
                <a class="rz-button rz-button--primary rz-button-group__button"
                   href="{{ path('settingsImportPage') }}">
                    <span class="rz-button__label">{{ 'import'|trans }}</span>
                    <span class="rz-button__icon rz-icon-ri--upload-line"></span>
                </a>
                {% if settingGroup is defined and settingGroup %}
                    <a class="rz-button rz-button--primary rz-button-group__button"
                       href="{{ path('settingsExportGroupPage', {settingGroupId: settingGroup.id}) }}">
                        <span class="rz-button__label">{{ 'export'|trans }}</span>
                        <span class="rz-button__icon rz-icon-ri--download-line"></span>
                    </a>
                {% else %}
                    <a class="rz-button rz-button--primary rz-button-group__button"
                       href="{{ path('settingsExportAllPage') }}">
                        <span class="rz-button__label">{{ 'export'|trans }}</span>
                        <span class="rz-button__icon rz-icon-ri--download-line"></span>
                    </a>
                {% endif %}
            </div>
        {% endif %}
    {% endblock %}

    {% block badges %}
        {% if filters is defined and filters and filters.itemCount %}
            {% import "@RoadizRozier/macros/rz_badge.html.twig" as rz_badge %}
            <div class="rz-page-header__item">
                {{ rz_badge.item(
                    label: '%count%.items'|transchoice(filters.itemCount)|raw,
                    size: 'sm',
                    color: 'default'
                ) }}
            </div>
        {% endif %}
    {% endblock %}

    {% block title %}
        <h1 class="rz-page-header__title rz-page-header__item">
            {% if settingGroup is defined and settingGroup %}
                {{ settingGroup.name|trans }}
            {% else %}
                {{ title|default('settings'|trans) }}
            {% endif %}
        </h1>
    {% endblock %}

    {% block subtitle %}
        {% if subtitle is defined and subtitle %}
            <p class="rz-page-header__subtitle">{{ subtitle }}</p>
        {% endif %}
    {% endblock %}

    {% block nav_bar %}
        {% if with_nav_bar is defined and with_nav_bar %}
            {% include '@RoadizRozier/settings/navBar.html.twig' with {current: current} %}
        {% endif %}
    {% endblock %}
{% endembed %}
