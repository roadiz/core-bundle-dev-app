{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}import.attribute{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global">
    {% include '@RoadizRozier/attributes/head.html.twig' with {
        title: 'import.attribute'|trans
    } only %}

    <article class="content content-no-action-menu">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form) }}
            {{ form_widget(form) }}
            <button type="submit" class="uk-button uk-button-primary"><i class="uk-icon-rz-upload"></i> {% trans %}import{% endtrans %}</button>
        {{ form_end(form) }}
    </article>
</section>
{% endblock %}
