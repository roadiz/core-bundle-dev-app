{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}add.a.customFormField{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global">

    <header class="content-header header-item header-item-add">
        <h1 class="content-title item-add-title">{% trans %}add.a.customFormField{% endtrans %}</h1>
         <a class="content-header-nav-back uk-navbar-content" href="{{ path('customFormFieldsListPage', { customFormId: customForm.getId }) }}" title="{% trans %}back_to.customFormFields{% endtrans %}" data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
    </header>

    <article class="content">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{- form_start(form, { 'attr': { 'id': "add-custom-form-field-form" }}) -}}
            {{ form_widget(form) }}
            {% import "@RoadizRozier/macros/rz_floating_bar.html.twig" as floating_bar %}
            {{ floating_bar.saveItem('#add-custom-form-field-form') }}
        {{- form_end(form) -}}
    </article>

    {% include '@RoadizRozier/custom-form-fields/actionsMenu.html.twig' %}
</section>
{% endblock %}
