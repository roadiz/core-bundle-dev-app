{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{{ "edit.group.%name%"|trans({'%name%': item.name})|u.truncate(25, '[…]', true) }} | {{ parent() }}{% endblock %}

{% block content %}
<section class="content-global edit-group">

    <header class="content-header header-group header-group-edit">
        <h1 class="content-title group-add-title">{{ "edit.group.%name%"|trans({'%name%': item.name})|u.truncate(25, '[…]', true) }}</h1>
        <a class="content-header-nav-back uk-navbar-content"
           href="{{ path('groupsHomePage') }}"
           title="{% trans %}back_to.groups{% endtrans %}"
           data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
        {% include '@RoadizRozier/groups/navBar.html.twig' with {'item': item, current: 'edit'} %}
    </header>

    <article class="content content-edit">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: { id: "edit-group-form" }}) }}
        {{ form_widget(form) }}
        {% import "@RoadizRozier/macros/rz_floating_bar.html.twig" as floating_bar %}
        {{ floating_bar.saveItem('#edit-group-form') }}
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/groups/actionsMenu.html.twig' %}
</section>
{% endblock %}
