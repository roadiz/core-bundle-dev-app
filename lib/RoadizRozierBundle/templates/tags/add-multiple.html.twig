{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {% trans %}add.multiple.tags{% endtrans %}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global">
    {% include '@RoadizRozier/tags/head.html.twig' with {
        title: 'add.multiple.tags'|trans,
        with_nav_bar: true,
        tag: tag,
        current: 'add-multiple'
    } only %}

    <article class="content content-tags-add">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, { attr: {id: 'add-tag-form'}}) }}
        {{ form_widget(form) }}
        <div class="rz-form-field rz-form-field--align-start">
            <button is="rz-button" class="rz-button rz-button--primary" data-action-save="#add-tag-form" type="submit">
                <span class="rz-button__label"> {% trans %}add_all{% endtrans %}</span>
                <span class="rz-button__icon rz-icon-ri--add-line"></span>
            </button>
        </div>
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/tags/actionsMenu.html.twig' %}
</section>
{% endblock %}
