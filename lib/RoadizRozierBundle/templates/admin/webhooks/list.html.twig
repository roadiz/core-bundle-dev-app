{% extends '@RoadizRozier/layout.html.twig' %}

{% block title %}{% trans %}webhooks{% endtrans %} | {{ parent() }}{% endblock %}

{% block content %}
<rz-bulk-section>
    {% include '@RoadizRozier/admin/head.html.twig' with {
        title: 'webhooks'|trans,
        filters: filters,
        buttons: [{
            label: 'add.a.webhook'|trans,
            href: path('webhooksAddPage'),
            icon: 'rz-icon-ri--add-line'
        }]
    } only %}

    {% include "@RoadizRozier/widgets/rz_filters_bar.html.twig" with {
        filters: filters,
        display_select_all_button: true,
    }  only %}
    {% include '@RoadizRozier/admin/bulk_actions.html.twig' %}

    <article class="content content-no-action-menu">
        <div class="content-table-cont">
            <table class="items content-table uk-table webhooks">
                <thead>
                <tr>
                    {% include '@RoadizRozier/admin/webhooks/webhook_row_header.html.twig' %}
                </tr>
                </thead>
                <tbody>
                {% for item in items %}
                    <tr>
                        {% include '@RoadizRozier/admin/webhooks/webhook_row.html.twig' %}
                    </tr>
                {% else %}
                    <tr><td colspan="6">{% trans %}no_webhooks{% endtrans %}</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </article>
</rz-bulk-section>
{% endblock %}
