{% extends '@RoadizRozier/layout.html.twig' %}

{%- block title -%}
    {{ "edit.redirection"|trans }}
    |
    {{ parent() -}}
{%- endblock -%}

{% block content %}
<section class="content-global">

    <header class="content-header header-redirection header-redirection-add">
        <h1 class="content-title">{{ "edit.redirection"|trans }}</h1>
        <a class="content-header-nav-back uk-navbar-content"
           href="{{ path('redirectionsHomePage') }}"
           title="{% trans %}back_to.redirections{% endtrans %}"
           data-uk-tooltip="{animation:true}"><i class="uk-icon-rz-back-parent"></i></a>
    </header>

    <article class="content">
        {% form_theme form '@RoadizRozier/forms.html.twig' %}
        {{ form_start(form, {attr:{id: 'edit-redirection-form'}}) }}
        {{ form_widget(form) }}
        {% import "@RoadizRozier/macros/rz_actions_menu.html.twig" as floating_bar %}
        {{ floating_bar.saveItem('#edit-redirection-form') }}
        {{ form_end(form) }}
    </article>

    {% include '@RoadizRozier/redirections/actionsMenu.html.twig' %}
</section>
{% endblock %}
